# Local .terraform directories (recreated with terraform init)
**/.terraform/*

# .tfstate files (contain secrets and are highly dynamic)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (likely to contain passwords/secrets)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json